{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="sheshine-why page-width section-{{ section.id }}-padding">
  {%- if section.settings.heading != blank -%}
    <h2 class="sheshine-why__heading sheshine-heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}
  <div class="sheshine-why__grid">
    {%- for block in section.blocks -%}
      <div class="sheshine-why__card" {{ block.shopify_attributes }}>
        <span class="sheshine-why__icon" aria-hidden="true">{{ block.settings.icon | escape }}</span>
        <h3 class="sheshine-why__title">{{ block.settings.title | escape }}</h3>
        <p class="sheshine-why__text">{{ block.settings.text | escape }}</p>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Why SheShine",
  "tag": "section",
  "class": "sheshine-why-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Women Love SheShine"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🇬🇧" },
        { "type": "text", "id": "title", "label": "Title", "default": "UK Based" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Fast dispatch from the UK" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why SheShine",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "🇬🇧",
            "title": "UK Based",
            "text": "Fast dispatch from the UK"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "🚚",
            "title": "Free Delivery",
            "text": "On orders over £25"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "↩️",
            "title": "Easy Returns",
            "text": "30-day hassle-free returns"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "⭐",
            "title": "Trusted Quality",
            "text": "4.9★ from 2,000+ customers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
