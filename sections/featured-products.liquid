{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign coll = section.settings.collection
  assign limit = section.settings.products_to_show
-%}

<div class="sheshine-featured page-width section-{{ section.id }}-padding">
  {%- if section.settings.heading != blank -%}
    <h2 class="sheshine-featured__heading sheshine-heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  {%- if coll != blank and coll.products_count > 0 -%}
    <div class="sheshine-featured__grid">
      {%- for product in coll.products limit: limit -%}
        <div>
          {% render 'product-card',
            product: product,
            lazy_load: forloop.index > 2,
            section_id: section.id
          %}
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.show_view_all and coll.url != blank -%}
      <div class="sheshine-featured__footer">
        <a class="sheshine-btn sheshine-btn--outline sheshine-btn--pill" href="{{ coll.url }}">
          {{ section.settings.view_all_label | escape }}
        </a>
      </div>
    {%- endif -%}
  {%- else -%}
    <p class="center">{{ 'sheshine.featured.pick_collection' | t }}</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "SheShine featured",
  "tag": "section",
  "class": "sheshine-featured-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Most Popular"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View All"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "presets": [{ "name": "SheShine featured" }]
}
{% endschema %}
