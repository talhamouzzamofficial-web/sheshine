<div
  class="sheshine-press{% if section.settings.full_width != false %} marquee-section{% endif %}"
  style="{% if section.settings.background != blank %}--sheshine-press-bg: {{ section.settings.background }};{% endif %}"
>
  <div class="press-bar">
    <div class="marquee-track">
      <div class="marquee-inner">
        <span>COSMOPOLITAN</span>
        <span class="marquee-dot">✦</span>
        <span>ELLE</span>
        <span class="marquee-dot">✦</span>
        <span>GLAMOUR</span>
        <span class="marquee-dot">✦</span>
        <span>LIFE&amp;STYLE</span>
        <span class="marquee-dot">✦</span>
        <span>VOGUE</span>
        <span class="marquee-dot">✦</span>
        <span>HARPER'S BAZAAR</span>
        <span class="marquee-dot">✦</span>
        <span>COSMOPOLITAN</span>
        <span class="marquee-dot">✦</span>
        <span>ELLE</span>
        <span class="marquee-dot">✦</span>
        <span>GLAMOUR</span>
        <span class="marquee-dot">✦</span>
        <span>LIFE&amp;STYLE</span>
        <span class="marquee-dot">✦</span>
        <span>VOGUE</span>
        <span class="marquee-dot">✦</span>
        <span>HARPER'S BAZAAR</span>
        <span class="marquee-dot">✦</span>
      </div>
    </div>
  </div>
</div>

{%- if section.settings.background != blank -%}
  <style>
    #shopify-section-{{ section.id }} .sheshine-press {
      background: var(--sheshine-press-bg);
    }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "SheShine press bar",
  "tag": "section",
  "class": "sheshine-press-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width (edge to edge)",
      "default": true
    },
    {
      "type": "textarea",
      "id": "marquee_text",
      "label": "Magazine names (use | between)",
      "default": "COSMOPOLITAN | ELLE | GLAMOUR | Life&Style | VOGUE | HARPER'S BAZAAR"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#FFB5B5"
    }
  ],
  "presets": [{ "name": "SheShine press bar" }]
}
{% endschema %}
