{%- style -%}
  #SheShineHero-{{ section.id }} .sheshine-hero__viewport {
    min-height: {{ section.settings.min_height }}px;
  }
{%- endstyle -%}

<div
  id="SheShineHero-{{ section.id }}"
  class="sheshine-hero"
  data-sheshine-hero
  data-autoplay-interval="{{ section.settings.autoplay_seconds | times: 1000 }}"
>
  <div class="sheshine-hero__viewport page-width">
    {%- for block in section.blocks -%}
      <div
        class="sheshine-hero__slide{% if forloop.first %} is-active{% endif %}"
        data-hero-slide
        {{ block.shopify_attributes }}
        style="
          {% if block.settings.image != blank %}
            background-image: url('{{ block.settings.image | image_url: width: 1800 }}');
          {% else %}
            background: linear-gradient(135deg, #e0e0e0 0%, #f5f5f5 50%, #d8d8d8 100%);
          {% endif %}
          background-size: cover;
          background-position: center;
        "
      >
        <div
          class="sheshine-hero__overlay"
          style="background: rgba(0,0,0,{{ block.settings.overlay_strength | divided_by: 100.0 }});"
        ></div>
        {% if block.settings.image == blank %}
          <div class="sheshine-hero__svg-wrap" aria-hidden="true">
            {{ 'hero-apparel-1' | placeholder_svg_tag: 'sheshine-hero__svg-placeholder' }}
          </div>
          <span class="sheshine-hero__placeholder-label">{{ 'sheshine.hero.upload_image' | t }}</span>
        {% endif %}
        <div class="sheshine-hero__slide-inner">
          <p class="sheshine-hero__label">{{ block.settings.label | escape }}</p>
          <h2 class="sheshine-hero__title">{{ block.settings.heading | escape }}</h2>
          <p class="sheshine-hero__text">{{ block.settings.subtext | escape }}</p>
          {%- if block.settings.button_label != blank -%}
            <a class="sheshine-btn sheshine-btn--light sheshine-btn--pill" href="{{ block.settings.button_link }}">
              {{- block.settings.button_label | escape -}}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}

    {%- if section.blocks.size > 1 -%}
      <button
        type="button"
        class="sheshine-hero__nav sheshine-hero__nav--prev"
        data-hero-prev
        aria-label="{{ 'general.pagination.previous' | t }}"
      >
        ‹
      </button>
      <button
        type="button"
        class="sheshine-hero__nav sheshine-hero__nav--next"
        data-hero-next
        aria-label="{{ 'general.pagination.next' | t }}"
      >
        ›
      </button>
      <div class="sheshine-hero__dots" role="tablist">
        {%- for block in section.blocks -%}
          <button
            type="button"
            class="sheshine-hero__dot{% if forloop.first %} is-active{% endif %}"
            data-hero-dot
            aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "SheShine hero slider",
  "tag": "section",
  "class": "sheshine-hero-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "range",
      "id": "min_height",
      "min": 360,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Minimum height",
      "default": 520
    },
    {
      "type": "range",
      "id": "autoplay_seconds",
      "min": 0,
      "max": 12,
      "step": 1,
      "unit": "sec",
      "label": "Autoplay interval",
      "default": 5,
      "info": "Set to 0 to disable autoplay"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "range",
          "id": "overlay_strength",
          "min": 0,
          "max": 90,
          "step": 5,
          "unit": "%",
          "label": "Dark overlay strength",
          "default": 45
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "NEW ARRIVAL"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Refined Beauty Essentials For Everyday Rituals"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext",
          "default": "Upgrade your routine with thoughtfully chosen essentials that feel soft, luxurious, and beautifully easy to use."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SheShine hero slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
