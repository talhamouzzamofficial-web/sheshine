{%- liquid
  assign threshold = section.settings.free_shipping_threshold | times: 100
  assign total = cart.total_price
  assign remain = threshold | minus: total
  assign pct = 0
  if threshold > 0
    assign pct = total | times: 100 | divided_by: threshold
    if pct > 100
      assign pct = 100
    endif
  endif
-%}

<div
  class="sheshine-cart-shipping page-width"
  data-sheshine-free-shipping
  data-threshold="{{ threshold }}"
  data-cart-total="{{ total }}"
  data-msg-remain="{{ 'sheshine.cart.away_from_free_js' | t }}"
  data-msg-complete="{{ 'sheshine.cart.unlocked_free' | t }}"
>
  <p class="sheshine-cart-shipping__msg" data-sheshine-shipping-msg>
    {%- if total >= threshold -%}
      {{ 'sheshine.cart.unlocked_free' | t }}
    {%- elsif remain > 0 -%}
      {% assign rem_str = remain | money %}
      {{ 'sheshine.cart.away_from_free' | t: amount: rem_str }}
    {%- else -%}
      {{ 'sheshine.cart.unlocked_free' | t }}
    {%- endif -%}
  </p>
  <div class="sheshine-cart-shipping__bar" aria-hidden="true">
    <div class="sheshine-cart-shipping__fill" data-sheshine-shipping-fill style="width: {{ pct }}%;"></div>
  </div>
</div>
{% schema %}
{
  "name": "Free shipping progress",
  "tag": "section",
  "class": "sheshine-cart-shipping-section",
  "settings": [
    {
      "type": "range",
      "id": "free_shipping_threshold",
      "min": 10,
      "max": 150,
      "step": 1,
      "unit": "£",
      "label": "Free shipping minimum (GBP)",
      "default": 25
    }
  ],
  "presets": [{ "name": "Free shipping progress" }]
}
{% endschema %}
