{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="sheshine-bestseller section-{{ section.id }}-padding">
  <div class="sheshine-bestseller__grid page-width">
    <div class="sheshine-bestseller__media">
      {%- if section.settings.image != blank -%}
        {% liquid
          assign img_alt = section.settings.image.alt | default: section.settings.title
        %}
        {{
          section.settings.image
          | image_url: width: 1000
          | image_tag: widths: '400, 600, 800, 1000', sizes: '(min-width: 990px) 45vw, 100vw', loading: 'lazy', alt: img_alt
        }}
      {%- elsif section.settings.product != blank and section.settings.product.featured_image != blank -%}
        {% liquid
          assign fimg = section.settings.product.featured_image
          assign falt = fimg.alt | default: section.settings.product.title
        %}
        {{
          fimg
          | image_url: width: 1000
          | image_tag: widths: '400, 600, 800, 1000', sizes: '(min-width: 990px) 45vw, 100vw', loading: 'lazy', alt: falt
        }}
      {%- else -%}
        {{ 'product-apparel-1' | placeholder_svg_tag: 'sheshine-bestseller__placeholder' }}
      {%- endif -%}
    </div>
    <div>
      {%- if section.settings.badge != blank -%}
        <p class="sheshine-bestseller__badge">{{ section.settings.badge | escape }}</p>
      {%- endif -%}
      <h2 class="sheshine-bestseller__title sheshine-heading">
        {%- if section.settings.product != blank -%}
          <a href="{{ section.settings.product.url }}">{{ section.settings.product.title | escape }}</a>
        {%- else -%}
          {{ section.settings.title | escape }}
        {%- endif -%}
      </h2>
      <ul class="sheshine-bestseller__bullets">
        {%- for block in section.blocks -%}
          {%- if block.type == 'bullet' -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
      {%- assign btn_link = section.settings.button_link -%}
      {%- if section.settings.product != blank and btn_link == blank -%}
        {%- assign btn_link = section.settings.product.url -%}
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a class="sheshine-btn sheshine-btn--primary sheshine-btn--pill" href="{{ btn_link }}">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
      {%- if section.settings.social_proof != blank -%}
        <p class="sheshine-bestseller__social">{{ section.settings.social_proof | escape }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bestseller highlight",
  "tag": "section",
  "class": "sheshine-bestseller-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Featured product"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image override"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title (if no product)",
      "default": "Flawless Facial Hair Remover"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "⭐ #1 Bestseller"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now — £5.99"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link override"
    },
    {
      "type": "text",
      "id": "social_proof",
      "label": "Social proof line",
      "default": "🔥 847 sold this week"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet",
      "settings": [{ "type": "text", "id": "text", "label": "Text", "default": "Gentle on sensitive skin" }]
    }
  ],
  "presets": [
    {
      "name": "Bestseller highlight",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Gentle on sensitive skin" } },
        { "type": "bullet", "settings": { "text": "Compact for on-the-go touch-ups" } },
        { "type": "bullet", "settings": { "text": "Loved by thousands of UK customers" } }
      ]
    }
  ]
}
{% endschema %}
