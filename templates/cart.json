{
  "sections": {
    "cart-shipping": {
      "type": "sheshine-cart-shipping",
      "settings": {
        "free_shipping_threshold": 25
      }
    },
    "cart-items": {
      "type": "main-cart-items",
      "settings": {
        "padding_top": 12,
        "padding_bottom": 12
      }
    },
    "cart-footer": {
      "type": "main-cart-footer",
      "blocks": {
        "subtotal": {
          "type": "subtotal",
          "settings": {}
        },
        "buttons": {
          "type": "buttons",
          "settings": {}
        }
      },
      "block_order": ["subtotal", "buttons"]
    },
    "you-might-like": {
      "type": "featured-collection",
      "settings": {
        "title": "You might also like...",
        "heading_size": "h2",
        "collection": "all",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "show_view_all": false,
        "swipe_on_mobile": false,
        "image_ratio": "square",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 36
      }
    }
  },
  "order": ["cart-shipping", "cart-items", "cart-footer", "you-might-like"]
}
